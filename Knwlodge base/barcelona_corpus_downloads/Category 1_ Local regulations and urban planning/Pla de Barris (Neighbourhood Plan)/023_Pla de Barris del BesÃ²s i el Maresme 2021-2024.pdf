  <div class="paragraph paragraph--type--page-summary paragraph--view-mode--default">
    <div class="container">
      <div class="page-summary-content">
                                        
  <h2 class="field--name-field-page-summary-title">Què fa el Pla de Barris als barris?</h2>

  <div class="field--name-field-page-summary-description"><p><span>Selecciona el Pla de Barris sobre el que et vols informar i filtra per àmbits i perfils d’actuació</span></p>
</div>

                        </div>
    </div>
  </div>

        <div class="paragraph paragraph--type--block-reference paragraph--view-mode--default">
          
  
<div id="block-minerva-subtheme-pladebarrismapaaccions" style="background-color: transparent">
  
    
      
<div class="block-mapa-accions">
  <div class="mapa-accions-wrapper">
    <div  data-component-id="accions:mapa_accions_filters">
    <button class="open-filters" type="button"><span class="icobcn-filtre-l-light" aria-hidden="true"></span></button>
  <section class="filters">
    <header>
      <h6 id="filtres-mapa">
        <span class="icobcn-filtre-l-light" aria-hidden="true"></span>
        Filtra per
      </h6>
      <button class="close-filters" type="button" aria-label="Tanca filtres"><span class="icobcn-creu-l"></span></button>
    </header>
    <section class="accordion">
      <p>
        <button type="button"
                class="accordion-titol"
                aria-expanded="false"
                aria-controls="bloc-ambits"
                id="btn-ambits">
          Àmbits d'actuació
        </button>
      </p>
      <div id="bloc-ambits" role="region" aria-labelledby="btn-ambits" class="filter-list">
        <ul>
          <li>
            <label>
              <input type="checkbox" name="ambits" value="all">
              <span>Tots els àmbits</span>
            </label>
          </li>
                    <li>
            <label>
              <input type="checkbox" name="ambits" value="117">
              <span>Educació i cultura</span>
            </label>
          </li>
                    <li>
            <label>
              <input type="checkbox" name="ambits" value="118">
              <span>Espai públic i accessibilitat</span>
            </label>
          </li>
                    <li>
            <label>
              <input type="checkbox" name="ambits" value="119">
              <span>Habitatge i rehabilitació</span>
            </label>
          </li>
                    <li>
            <label>
              <input type="checkbox" name="ambits" value="120">
              <span>Salut, benestar i comunitat</span>
            </label>
          </li>
                    <li>
            <label>
              <input type="checkbox" name="ambits" value="121">
              <span>Desenvolupament socio-econòmic i ocupació</span>
            </label>
          </li>
                    <li>
            <label>
              <input type="checkbox" name="ambits" value="122">
              <span>Adaptació climàtica, transició energètica i verd urbà</span>
            </label>
          </li>
                  </ul>
      </div>
    </section>
    <section class="accordion">
      <p>
        <button type="button"
                class="accordion-titol"
                aria-expanded="false"
                aria-controls="bloc-perfils"
                id="btn-perfils">
          Perfils d'actuació
        </button>
      </p>
      <div id="bloc-perfils" role="region" aria-labelledby="btn-perfils" class="filter-list hidden">
        <ul>
          <li>
            <label>
              <input type="checkbox" name="perfils" value="all">
              <span>Tots els perfils</span>
            </label>
          </li>
                    <li>
            <label>
              <input type="checkbox" name="perfils" value="1,2,3">
              <span>Joves (Joves, Adolescents i Infancia)</span>
            </label>
          </li>
