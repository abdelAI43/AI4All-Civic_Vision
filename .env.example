# Mapbox GL API Token
# Get your free token at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ---- Voice Interaction Backend ----
# These are used by the proxy server (server/), NOT the frontend.
# Get your OpenAI key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Get your Replicate token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# NanoBanana model version hash from Replicate
NANO_BANANA_MODEL_VERSION=your_model_version_here

# Proxy server port (default: 3001)
SERVER_PORT=3001
