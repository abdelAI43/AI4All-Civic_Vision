# ── Client-side (safe to expose in browser) ──────────────────────────────────
# Mapbox GL map rendering — get a free token at https://account.mapbox.com
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Supabase project URL and anon key (read-only queries from browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Server-only (NEVER prefix with VITE_ — not accessible in browser) ────────

# Your deployment origin — used by serverless functions to fetch base POV images.
# Local dev: http://localhost:5173  |  Production: https://your-app.vercel.app
APP_URL=http://localhost:5173

# Google AI Studio — Nano Banana Pro image gen + Gemini Flash validation
# Get your key at: https://aistudio.google.com/u/1/api-keys
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# OpenAI — specialist agent evaluations (5 agents in parallel)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase service role key — for server-side writes (proposals, storage)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
